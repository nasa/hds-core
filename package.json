{
  "name": "@nasa/hds-core",
  "version": "0.2.0",
  "description": "NASA Horizon Design System (HDS) Core — design tokens, base styles, and USWDS theme configuration.",
  "license": "SEE LICENSE.MD",
  "private": true,
  "main": "dist/js/hds-core.umd.js",
  "exports": {
    ".": {
      "import": "./dist/js/hds-core.esm.js",
      "require": "./dist/js/hds-core.umd.js"
    },
    "./css": "./dist/css/hds-core.css",
    "./css/min": "./dist/css/hds-core.min.css",
    "./scss": "./src/scss/styles.scss",
    "./assets": "./dist/assets/"
  },
  "files": [
    "dist/",
    "src/scss/",
    "src/assets/"
  ],
  "scripts": {
    "build": "gulp build",
    "copy:assets": "gulp copyAssets",
    "watch": "gulp watch",
    "init": "gulp init",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "@uswds/uswds": "^3.13.0"
  },
  "devDependencies": {
    "@uswds/compile": "^1.0.0",
    "gulp": "^4.0.2",
    "gulp-svg-sprite": "^2.0.3",
    "storybook": "^10.2.17",
    "@storybook/html-vite": "^10.2.17",
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-vitest": "^10.2.17",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-docs": "^10.2.17",
    "vitest": "^4.1.0",
    "playwright": "^1.58.2",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0"
  },
  "keywords": [
    "nasa",
    "hds",
    "horizon-design-system",
    "uswds",
    "design-tokens",
    "sass"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nasa/hds-core.git"
  },
  "dependencies": {
    "@nasa/hds-core": "github:nasa/hds-core"
  }
}
